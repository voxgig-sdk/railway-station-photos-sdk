# Guide

guide: {
  metrics: count: entity: 16
  metrics: count: path: 26
  metrics: count: method: 30

  entity: admin_inbox: {
    path: "/adminInbox": {
      op: create: method: *POST
    }
  }

  entity: country: {
    path: "/countries": {
      op: list: method: *GET
    }
  }

  entity: inbox: {
    path: "/reportProblem": {
      op: create: method: *POST
    }
