    path: "/oauth2/authorize": {
      op: load: method: *GET
    }
    path: "/oauth2/revoke": {
      op: create: method: *POST
    }
  }

  entity: photo: {
    path: "/photos/{country}/{filename}": {
      op: load: method: *GET
    }
  }

  entity: photo_download: {
    path: "/inbox/done/{filename}": {
      op: load: method: *GET
    }
    path: "/inbox/processed/{filename}": {
      op: load: method: *GET
    }
    path: "/inbox/rejected/{filename}": {
      op: load: method: *GET
    }
    path: "/inbox/{filename}": {
      op: load: method: *GET
    }
  }

  entity: photo_station: {
    path: "/photoStationById/{country}/{id}": {
      op: list: method: *GET
    }
    path: "/photoStationsByCountry/{country}": {
      op: load: method: *GET
    }
    path: "/photoStationsByPhotographer/{photographer}": {
      op: load: method: *GET
    }
    path: "/photoStationsByRecentPhotoImports": {
      op: list: method: *GET
    }
  }

  entity: photo_upload: {
    path: "/photoUpload": {
      op: create: method: *POST
    }
  }

  entity: photographer: {
