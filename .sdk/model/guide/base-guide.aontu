      op: create: method: *POST
      op: list: method: *GET
    }
    path: "/userInbox/{id}": {
      op: remove: method: *DELETE
    }
  }

  entity: inbox_count: {
    path: "/adminInboxCount": {
      op: load: method: *GET
    }
  }

  entity: inbox_entry: {
